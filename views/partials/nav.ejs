<%
  // currentPath is passed by each route; defaults keep the partial safe
  const cp = typeof currentPath !== "undefined" ? currentPath : "";
  const links = [
    { href: "/#about",     label: "About" },
    { href: "/#domains",   label: "Domains" },
    { href: "/faculty",    label: "Faculty" },
    { href: "/team",       label: "Team" },
    { href: "/events",     label: "Events" },
    { href: "/inaugural",  label: "Inaugural" },
    { href: "/blogs",      label: "Blogs" },
    { href: "/#ms-tech",   label: "Resources" },
    { href: "/#contact",   label: "Contact" }
  ];
%>
<header>
  <div class="nav">
    <a href="/" class="brand">
      <img class="brand-mark" src="/MSA_LOGO.jpeg" alt="MSA GNIT logo">
      <div class="brand-text">
        <div class="l1">Microsoft Student Ambassadors,</div>
        <div class="l1">GNIT Chapter</div>
      </div>
    </a>
    <nav class="links">
      <% links.forEach(l => { %>
        <a href="<%= l.href %>" <%= l.href === cp ? 'aria-current="page"' : "" %>><%= l.label %></a>
      <% }) %>
    </nav>
    <a href="/#collaborate" class="nav-cta"><span>Join the Chapter <span class="arrow-inline">→</span></span></a>
    <button class="nav-toggle" aria-label="menu">☰</button>
  </div>
</header>

<div class="scrim"></div>
<nav class="mobile-panel">
  <a href="/">Home</a>
  <a href="/#about"><b>About</b></a>
  <a href="/#domains"><b>Domains</b></a>
  <a href="/faculty"><b>Faculty</b></a>
  <a href="/team"><b></b>Team</b></a>
  <a href="/events"><b>Events</b></a>
  <a href="/inaugural"><b>Inaugural</b></a>
  <a href="/blogs"><b>Blogs</b></a>
  <a href="/#ms-tech"><b>Microsoft Tech</b></a>
  <a href="/#collaborate"><b>Collaborate</b></a>
  <a href="/#contact"><b>Contact</b></a>
</nav>
