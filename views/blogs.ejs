<!DOCTYPE html>
<html lang="en">
<head>
<%- include("partials/head") %>
<style>
  .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .blog-card{
    display:flex;flex-direction:column;
    background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));
    border:1px solid var(--line);border-radius:16px;overflow:hidden;
    transition:transform .35s cubic-bezier(.16,.84,.44,1), border-color .3s ease, box-shadow .3s ease;
  }
  .blog-card:hover{transform:translateY(-6px);border-color:rgba(217,72,27,0.4);box-shadow:0 24px 44px -26px rgba(216,59,1,0.55);}
  .blog-banner{
    aspect-ratio:16/9;position:relative;overflow:hidden;
    display:flex;align-items:flex-end;padding:16px 22px;
  }
  .blog-banner img{
    position:absolute;inset:0;width:100%;height:100%;
    object-fit:cover;object-position:center;
    transition:transform .45s cubic-bezier(.16,.84,.44,1);
  }
  .blog-card:hover .blog-banner img{transform:scale(1.05);}
  .blog-banner::after{content:'';position:absolute;inset:0;background:linear-gradient(0deg, rgba(30,10,6,0.5), transparent 55%);}
  .blog-banner .b-tag{
    position:relative;z-index:1;
    font-family:var(--font-mono);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;
    padding:5px 10px;border-radius:999px;
    background:rgba(30,10,6,0.55);backdrop-filter:blur(6px);
    border:1px solid rgba(255,255,255,0.18);color:#fff;
  }
  .blog-body{padding:24px 24px 26px;display:flex;flex-direction:column;gap:12px;flex:1;}
  .blog-meta{font-family:var(--font-mono);font-size:11.5px;color:var(--text-dim);letter-spacing:.03em;display:flex;gap:14px;flex-wrap:wrap;}
  .blog-body h3{font-family:var(--font-display);font-size:19px;font-weight:700;color:var(--text-hi);line-height:1.35;}
  .blog-body p{color:var(--text-mid);font-size:14px;line-height:1.7;flex:1;}
  .blog-author{display:flex;align-items:center;gap:10px;margin-top:4px;}
  .blog-author .ba-avatar{
    width:30px;height:30px;border-radius:50%;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--font-display);font-weight:700;font-size:11px;color:#fff;
  }
  .blog-author span{font-size:13px;color:var(--text-mid);}
  .blog-link{
    margin-top:10px;display:inline-flex;align-items:center;gap:7px;
    font-family:var(--font-mono);font-size:12.5px;color:var(--cyan);
  }
  .blog-link svg{width:13px;height:13px;stroke:currentColor;fill:none;transition:transform .25s ease;}
  .blog-card:hover .blog-link svg{transform:translate(3px,-3px);}
  @media (max-width:960px){.blog-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>

<%- include("partials/nav") %>

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">Written by the chapter</div>
    <h1>MSA GNIT <span class="grad">Blogs</span></h1>
    <p>Certification offers, global events, and chapter news from the Microsoft ecosystem — curated for GNIT students.</p>
  </div>
</section>

<%
  const B_GRADIENTS = [
    "linear-gradient(135deg,#d83b01,#6e1423)",
    "linear-gradient(135deg,#e8532e,#d83b01)",
    "linear-gradient(135deg,#6e1423,#ffb900)",
    "linear-gradient(135deg,#ffb900,#e8532e)"
  ];
  const initialsOf = n => n.split(/\s+/).filter(Boolean).slice(0,2).map(p=>p[0]).join("").toUpperCase();
%>

<section id="posts" style="padding-top:40px;">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Announcements &amp; opportunities</div>
        <h2>Latest <span>Updates</span></h2>
      </div>
      <p>Updates open on the platform where they were published. Edit <code style="font-family:var(--font-mono);font-size:12px;color:var(--cyan);">data/blogs.js</code> to add yours.</p>
    </div>
    <div class="blog-grid">
      <% blogs.forEach((post, i) => { %>
        <a class="blog-card reveal" href="<%= post.link %>" target="_blank" rel="noopener">
          <div class="blog-banner" style="background:<%= post.banner || B_GRADIENTS[i % B_GRADIENTS.length] %>">
            <% if (post.image) { %><img src="/<%= post.image %>" alt="<%= post.title %>" loading="lazy" onerror="this.remove()"><% } %>
            <span class="b-tag"><%= post.tag %></span>
          </div>
          <div class="blog-body">
            <div class="blog-meta">
              <span><%= post.date %></span>
              <% if (post.readTime) { %><span><%= post.readTime %></span><% } %>
            </div>
            <h3><%= post.title %></h3>
            <p><%= post.excerpt %></p>
            <div class="blog-author">
              <div class="ba-avatar" style="background:<%= B_GRADIENTS[(i+1) % B_GRADIENTS.length] %>"><%= initialsOf(post.author) %></div>
              <span><%= post.author %></span>
            </div>
            <span class="blog-link">Read post <svg viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10"/></svg></span>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="cta-panel">
    <div class="cta-inner reveal">
      <div>
        <h2>Got something worth writing about?</h2>
        <p>Any chapter member can publish a recap, tutorial, or opinion piece here.</p>
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="mailto:msagnit@outlook.com?subject=Blog%20Submission" class="btn btn-primary">Write for us <span class="arrow">↗</span></a>
        <a href="https://www.linkedin.com/company/msa-gnit/posts/?feedView=all" target="_blank" rel="noopener" class="btn btn-ghost">All posts on LinkedIn</a>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>

</body>
</html>
