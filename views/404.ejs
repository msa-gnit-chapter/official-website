<!DOCTYPE html>
<html lang="en">
<head>
<%- include("partials/head") %>
<style>
  .nf{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 32px;}
  .nf-inner > *{opacity:0;animation:fadeUp .8s cubic-bezier(.16,.84,.44,1) forwards;}
  .nf .code{
    font-family:var(--font-display);font-weight:800;font-size:clamp(80px,16vw,160px);line-height:1;
    background:linear-gradient(100deg,var(--cyan),var(--azure) 55%,var(--violet));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }
  .nf h1{font-family:var(--font-display);font-size:clamp(20px,3vw,28px);margin-top:18px;animation-delay:.12s;}
  .nf p{color:var(--text-mid);margin-top:12px;font-size:15px;animation-delay:.24s;}
  .nf .btn{margin-top:32px;animation-delay:.36s;}
</style>
</head>
<body>

<%- include("partials/nav") %>

<section class="nf">
  <div class="nf-inner">
    <div class="code">404</div>
    <h1>This page doesn't exist.</h1>
    <p>The link may be broken, or the page may have moved.</p>
    <a href="/" class="btn btn-primary">Back to home <span class="arrow">↗</span></a>
  </div>
</section>

<%- include("partials/footer") %>

</body>
</html>
