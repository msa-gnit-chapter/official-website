<!DOCTYPE html>
<html lang="en">
<head>
<%- include("partials/head") %>
<style>
  /* ---------- shared photo-card person ---------- */
  .fac-person{
    background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));
    border:1px solid var(--line);
    border-radius:16px;
    padding:26px 26px 28px;
    display:flex;flex-direction:column;align-items:flex-start;
    transition:border-color .3s ease, transform .3s cubic-bezier(.16,.84,.44,1), box-shadow .3s ease;
    position:relative;overflow:hidden;
  }
  .fac-person::before{
    content:'';position:absolute;top:0;left:0;right:0;height:2px;
    background:linear-gradient(90deg,var(--cyan),var(--violet));
    transform:scaleX(0);transform-origin:left;
    transition:transform .35s cubic-bezier(.16,.84,.44,1);
  }
  .fac-person:hover::before{transform:scaleX(1);}
  .fac-person:hover{transform:translateY(-6px);border-color:rgba(217,72,27,0.35);box-shadow:0 20px 40px -24px rgba(216,59,1,0.5);}

  /* large photo frame (fills / placeholder) */
  .fac-photo{
    width:100%;aspect-ratio:4/3;border-radius:14px;overflow:hidden;position:relative;
    margin-bottom:20px;flex-shrink:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;
    background:rgba(216,59,1,0.07);
    border:1.5px dashed rgba(216,59,1,0.35);
    color:var(--text-dim);
    transition:border-color .3s ease, background .3s ease;
  }
  .fac-person:hover .fac-photo{border-color:rgba(217,72,27,0.5);background:rgba(216,59,1,0.12);}
  .fac-photo svg{width:34px;height:34px;stroke:var(--text-dim);fill:none;}
  .fac-photo span{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.05em;text-transform:uppercase;}
  .fac-photo.has-photo{border-style:solid;border-color:var(--line);background:none;}
  .fac-photo img{width:100%;height:100%;object-fit:cover;transition:transform .45s cubic-bezier(.16,.84,.44,1);}
  .fac-person:hover .fac-photo.has-photo img{transform:scale(1.05);}

  .fac-person h3{font-family:var(--font-display);font-size:19px;font-weight:700;color:var(--text-hi);}
  .fac-person .role{
    font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;
    color:var(--cyan);margin-top:8px;
  }
  .fac-person .dept{color:var(--text-dim);font-size:13px;margin-top:6px;}
  .fac-person .intro{color:var(--text-mid);font-size:13.5px;line-height:1.7;margin-top:12px;flex:1;}
  .fac-person .plinks{display:flex;gap:10px;margin-top:16px;}
  .fac-person .plinks a{
    width:32px;height:32px;border-radius:8px;border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;color:var(--text-mid);
    transition:border-color .25s ease, color .25s ease, transform .25s ease;
  }
  .fac-person .plinks a:hover{border-color:var(--cyan);color:var(--cyan);transform:translateY(-2px);}
  .fac-person .plinks svg{width:15px;height:15px;}

  /* ---------- principal: single wide featured card ---------- */
  .principal-card{display:grid;grid-template-columns:0.9fr 1.1fr;gap:0;padding:0;overflow:hidden;}
  .principal-card .fac-photo{margin-bottom:0;border-radius:0;border:none;aspect-ratio:auto;min-height:100%;}
  .principal-card .fac-photo.has-photo{border:none;}
  .principal-card .p-body{padding:40px 40px;display:flex;flex-direction:column;justify-content:center;}
  .principal-card h3{font-size:26px;}
  .principal-card .intro{font-size:15px;flex:none;}

  /* ---------- in-charge grid ---------- */
  .incharge-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;max-width:820px;}

  @media (max-width:820px){
    .principal-card{grid-template-columns:1fr;}
    .principal-card .fac-photo{aspect-ratio:16/10;min-height:0;}
    .incharge-grid{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<%- include("partials/nav") %>

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">With the blessings of our institution</div>
    <h1>Our <span class="grad">Faculty</span></h1>
    <p>The leadership and mentorship from Guru Nanak Institute of Technology that guides and empowers the MSA-GNIT chapter.</p>
  </div>
</section>

<%
  // camera-icon placeholder SVG reused for empty photo frames
  const camSvg = '<svg viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>';
  const liSvg = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.11 20.45H3.56V9h3.55v11.45z"/></svg>';
  const mailSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l9 6 9-6"/></svg>';
%>

<!-- ---------- Principal ---------- -->
<section id="principal" style="padding-top:40px;padding-bottom:60px;">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Institutional leadership</div>
        <h2>From the <span>Principal</span></h2>
      </div>
      <p>Guiding the institution that makes student-led innovation possible.</p>
    </div>
    <div class="fac-person principal-card reveal">
      <div class="fac-photo <%= principal.photo ? 'has-photo' : '' %>">
        <% if (principal.photo) { %>
          <img src="/<%= principal.photo %>" alt="<%= principal.name %>">
        <% } else { %>
          <%- camSvg %><span>Add photo — data/faculty.js</span>
        <% } %>
      </div>
      <div class="p-body">
        <h3><%= principal.name %></h3>
        <div class="role"><%= principal.role %></div>
        <% if (principal.dept) { %><div class="dept"><%= principal.dept %></div><% } %>
        <% if (principal.intro) { %><p class="intro"><%= principal.intro %></p><% } %>
        <% if (principal.linkedin || principal.email) { %>
          <div class="plinks">
            <% if (principal.linkedin) { %><a href="<%= principal.linkedin %>" target="_blank" rel="noopener" aria-label="<%= principal.name %> on LinkedIn"><%- liSvg %></a><% } %>
            <% if (principal.email) { %><a href="mailto:<%= principal.email %>" aria-label="Email <%= principal.name %>"><%- mailSvg %></a><% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- ---------- Faculty In-charge ---------- -->
<section id="faculty-incharge" style="padding-top:0;">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Chapter mentorship</div>
        <h2>Faculty <span>In-charge</span></h2>
      </div>
      <p>The faculty who mentor, guide, and champion the chapter day to day.</p>
    </div>
    <div class="incharge-grid">
      <% facultyIncharge.forEach(f => { %>
        <div class="fac-person reveal">
          <div class="fac-photo <%= f.photo ? 'has-photo' : '' %>">
            <% if (f.photo) { %>
              <img src="/<%= f.photo %>" alt="<%= f.name %>">
            <% } else { %>
              <%- camSvg %><span>Add photo — data/faculty.js</span>
            <% } %>
          </div>
          <h3><%= f.name %></h3>
          <div class="role"><%= f.role %></div>
          <% if (f.dept) { %><div class="dept"><%= f.dept %></div><% } %>
          <% if (f.intro) { %><p class="intro"><%= f.intro %></p><% } %>
          <% if (f.linkedin || f.email) { %>
            <div class="plinks">
              <% if (f.linkedin) { %><a href="<%= f.linkedin %>" target="_blank" rel="noopener" aria-label="<%= f.name %> on LinkedIn"><%- liSvg %></a><% } %>
              <% if (f.email) { %><a href="mailto:<%= f.email %>" aria-label="Email <%= f.name %>"><%- mailSvg %></a><% } %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="cta-panel">
    <div class="cta-inner reveal">
      <div>
        <h2>Meet the students behind the chapter.</h2>
        <p>See the core team and domain leads who run MSA-GNIT.</p>
      </div>
      <a href="/team" class="btn btn-primary">Meet the team <span class="arrow">↗</span></a>
    </div>
  </div>
</div>

<%- include("partials/footer") %>

</body>
</html>
