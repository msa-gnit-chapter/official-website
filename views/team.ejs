<!DOCTYPE html>
<html lang="en">
<head>
<%- include("partials/head") %>
<style>
  .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .advisor-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .person{
    background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));
    border:1px solid var(--line);
    border-radius:16px;
    padding:30px 26px 26px;
    display:flex;flex-direction:column;align-items:flex-start;gap:0;
    transition:border-color .3s ease, transform .3s cubic-bezier(.16,.84,.44,1), box-shadow .3s ease;
    position:relative;overflow:hidden;
  }
  .person::before{
    content:'';position:absolute;top:0;left:0;right:0;height:2px;
    background:linear-gradient(90deg,var(--cyan),var(--violet));
    transform:scaleX(0);transform-origin:left;
    transition:transform .35s cubic-bezier(.16,.84,.44,1);
  }
  .person:hover::before{transform:scaleX(1);}
  .person:hover{transform:translateY(-6px);border-color:rgba(217,72,27,0.35);box-shadow:0 20px 40px -24px rgba(216,59,1,0.5);}
  .avatar{
    width:76px;height:76px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--font-display);font-weight:700;font-size:24px;color:#fff;
    margin-bottom:18px;
    border:2px solid rgba(255,255,255,0.14);
    box-shadow:0 8px 24px -10px rgba(216,59,1,0.6);
    overflow:hidden;flex-shrink:0;
    transition:transform .35s cubic-bezier(.16,.84,.44,1);
  }
  .person:hover .avatar{transform:scale(1.06) rotate(-3deg);}
  .avatar img{width:100%;height:100%;object-fit:cover;}
  .person h3{font-family:var(--font-display);font-size:17.5px;font-weight:700;color:var(--text-hi);}
  .person .role{
    font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;
    color:var(--cyan);margin-top:6px;
  }
  .person .intro{color:var(--text-mid);font-size:13.5px;line-height:1.7;margin-top:12px;flex:1;}
  .person .plinks{display:flex;gap:10px;margin-top:16px;}
  .person .plinks a{
    width:30px;height:30px;border-radius:7px;border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;color:var(--text-mid);
    transition:border-color .25s ease, color .25s ease, transform .25s ease;
  }
  .person .plinks a:hover{border-color:var(--cyan);color:var(--cyan);transform:translateY(-2px);}
  .person.placeholder{border-style:dashed;opacity:.75;}
  .person.placeholder .avatar{background:rgba(216,59,1,0.12) !important;color:var(--text-dim);border-style:dashed;}

  .advisor-grid .person{padding:34px 30px 30px;}
  .advisor-grid .avatar{width:88px;height:88px;font-size:28px;}

  /* large photo frame for chapter lead & advisors (photoCard: true) */
  .photo-frame{
    width:100%;aspect-ratio:4/3;border-radius:12px;overflow:hidden;
    margin-bottom:18px;flex-shrink:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;
    background:rgba(216,59,1,0.07);
    border:1.5px dashed rgba(216,59,1,0.35);
    color:var(--text-dim);
    transition:border-color .3s ease, background .3s ease;
  }
  .person:hover .photo-frame{border-color:rgba(217,72,27,0.5);background:rgba(216,59,1,0.12);}
  .photo-frame svg{width:30px;height:30px;stroke:var(--text-dim);fill:none;}
  .photo-frame span{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.05em;text-transform:uppercase;}
  .photo-frame.has-photo{border-style:solid;border-color:var(--line);}
  .photo-frame img{width:100%;height:100%;object-fit:cover;}

  @media (max-width:900px){.team-grid{grid-template-columns:repeat(2,1fr);}.advisor-grid{grid-template-columns:1fr;}}
  @media (max-width:560px){.team-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>

<%- include("partials/nav") %>

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">The people behind the chapter</div>
    <h1>Meet the <span class="grad">Team</span></h1>
    <p>Student leads who run the domains, and the advisors who guide us — the humans behind every workshop, hackathon, and late-night deploy.</p>
  </div>
</section>

<%
  // gradient pool for monogram avatars
  const AV_GRADIENTS = [
    "linear-gradient(135deg,#d83b01,#6e1423)",
    "linear-gradient(135deg,#e8532e,#d83b01)",
    "linear-gradient(135deg,#6e1423,#ffb900)",
    "linear-gradient(135deg,#ffb900,#e8532e)",
    "linear-gradient(135deg,#d83b01,#e8532e)",
    "linear-gradient(135deg,#6e1423,#d83b01)"
  ];
  const initialsOf = n => n.split(/\s+/).filter(Boolean).slice(0,2).map(p=>p[0]).join("").toUpperCase();
  // empty names and "Add ..." names both render as dashed placeholder cards
  const isPlaceholder = n => !n || !n.trim() || n.trim().toLowerCase().startsWith("add ");
  const displayName = n => (n && n.trim()) ? n.trim() : "To be announced";
%>

<section id="core-team" style="padding-top:40px;">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Domain leads &amp; office bearers</div>
        <h2>Core <span>Team</span></h2>
      </div>
      <p>The student leads who plan, build, and run everything MSA GNIT does.</p>
    </div>
    <div class="team-grid">
      <% coreTeam.forEach((m, i) => { %>
        <div class="person reveal <%= isPlaceholder(m.name) ? "placeholder" : "" %>">
          <% if (m.photoCard) { %>
            <div class="photo-frame <%= m.photo ? "has-photo" : "" %>">
              <% if (m.photo) { %><img src="/<%= m.photo %>" alt="<%= displayName(m.name) %>"><% } else { %>
                <svg viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>
                <span>Add photo — data/team.js</span>
              <% } %>
            </div>
          <% } else { %>
            <div class="avatar" style="background:<%= AV_GRADIENTS[i % AV_GRADIENTS.length] %>">
              <% if (m.photo) { %><img src="/<%= m.photo %>" alt="<%= displayName(m.name) %>"><% } else { %><%= isPlaceholder(m.name) ? "?" : initialsOf(m.name) %><% } %>
            </div>
          <% } %>
          <h3><%= displayName(m.name) %></h3>
          <div class="role"><%= m.role %></div>
          <p class="intro"><%= m.intro %></p>
          <% if (m.linkedin || m.github) { %>
            <div class="plinks">
              <% if (m.linkedin) { %><a href="<%= m.linkedin %>" target="_blank" rel="noopener" aria-label="<%= m.name %> on LinkedIn"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.11 20.45H3.56V9h3.55v11.45z"/></svg></a><% } %>
              <% if (m.github) { %><a href="<%= m.github %>" target="_blank" rel="noopener" aria-label="<%= m.name %> on GitHub"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.38 7.86 10.9.57.1.78-.25.78-.55v-2c-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.06-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.38.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.2 1.18a11.1 11.1 0 015.83 0c2.22-1.49 3.19-1.18 3.19-1.18.64 1.58.24 2.75.12 3.04.74.8 1.18 1.82 1.18 3.08 0 4.41-2.7 5.38-5.26 5.67.42.36.78 1.08.78 2.18v3.24c0 .31.2.66.79.55A10.51 10.51 0 0023.5 12c0-6.27-5.23-11.5-11.5-11.5z"/></svg></a><% } %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section id="advisors" style="padding-top:0;">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Guidance &amp; mentorship</div>
        <h2>Our <span>Advisors</span></h2>
      </div>
      <p>Faculty and industry mentors who keep the chapter ambitious and on track.</p>
    </div>
    <div class="advisor-grid">
      <% advisors.forEach((a, i) => { %>
        <div class="person reveal <%= isPlaceholder(a.name) ? "placeholder" : "" %>">
          <% if (a.photoCard) { %>
            <div class="photo-frame <%= a.photo ? "has-photo" : "" %>">
              <% if (a.photo) { %><img src="/<%= a.photo %>" alt="<%= displayName(a.name) %>"><% } else { %>
                <svg viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>
                <span>Add photo — data/team.js</span>
              <% } %>
            </div>
          <% } else { %>
            <div class="avatar" style="background:<%= AV_GRADIENTS[(i+2) % AV_GRADIENTS.length] %>">
              <% if (a.photo) { %><img src="/<%= a.photo %>" alt="<%= displayName(a.name) %>"><% } else { %><%= isPlaceholder(a.name) ? "?" : initialsOf(a.name) %><% } %>
            </div>
          <% } %>
          <h3><%= displayName(a.name) %></h3>
          <div class="role"><%= a.role %></div>
          <p class="intro"><%= a.intro %></p>
          <% if (a.linkedin) { %>
            <div class="plinks">
              <a href="<%= a.linkedin %>" target="_blank" rel="noopener" aria-label="<%= a.name %> on LinkedIn"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.11 20.45H3.56V9h3.55v11.45z"/></svg></a>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="cta-panel">
    <div class="cta-inner reveal">
      <div>
        <h2>Want to see your face on this page?</h2>
        <p>Core team recruitment opens every year — any GNIT student can apply.</p>
      </div>
      <a href="mailto:msagnit@outlook.com?subject=Core%20Team%20Application" class="btn btn-primary">Apply for core team <span class="arrow">↗</span></a>
    </div>
  </div>
</div>

<%- include("partials/footer") %>

</body>
</html>
