<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // rotating word in the headline — "Student" stays constant,
  // the third word cycles: Ambassadors → Leader → Contributor → Developer
  const heroWord = document.getElementById('heroWord');
  const heroWords = ['Ambassadors', 'Leader', 'Contributor', 'Developer'];
  let heroWordIndex = 0;
  if(heroWord && !prefersReduced){
    setInterval(() => {
      heroWord.classList.add('swap');
      setTimeout(() => {
        heroWordIndex = (heroWordIndex + 1) % heroWords.length;
        heroWord.textContent = heroWords[heroWordIndex];
        heroWord.classList.remove('swap');
      }, 360);
    }, 2600);
  }

  // animated stat counters, triggered once when hero stats enter view
  const statEls = document.querySelectorAll('.hero-stats .num');
  function animateCount(el){
    const target = parseInt(el.dataset.count, 10);
    const suffix = el.dataset.suffix || '';
    const duration = 1100;
    const start = performance.now();
    function tick(now){
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if(p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  if(prefersReduced){
    statEls.forEach(el => el.textContent = el.dataset.count + (el.dataset.suffix||''));
  } else {
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          statEls.forEach(animateCount);
          statObserver.disconnect();
        }
      });
    }, { threshold: 0.4 });
    statObserver.observe(document.querySelector('.hero-stats'));
  }

</script>

