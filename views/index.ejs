<!DOCTYPE html>
<html lang="en">
<head>
<%- include("partials/head") %>
<style>
  /* ---------- Microsoft signature touches (home only) ---------- */
  /* four-square color strip along the very top of the page */
  header::before{
    content:'';position:absolute;top:0;left:0;right:0;height:3px;z-index:1;
    background:linear-gradient(90deg,
      #f25022 0 25%, #7fba00 25% 50%, #00a4ef 50% 75%, #ffb900 75% 100%);
  }
  /* four-square mark inside the hero eyebrow */
  .hero .eyebrow .ms-squares{margin-right:2px;}

  /* ---------- hero (home only) ---------- */
  .hero{
    position:relative;
    min-height:88vh;
    display:flex;flex-direction:column;justify-content:center;
    padding:calc(var(--header-h) + 60px) 32px 80px;
    overflow:hidden;
  }
  /* Windows-bloom style image background (replace /public/hero-bloom.jpg
     with the official wallpaper any time — same filename, no code change).
     The image "pops in" when the site first opens: it fades in while
     zooming from 118% down to 100% and sharpening from a soft blur. */
  @keyframes bloomPop{
    0%{opacity:0;transform:scale(1.18);filter:blur(18px) saturate(1.15);}
    55%{opacity:1;}
    100%{opacity:1;transform:scale(1);filter:blur(0) saturate(1);}
  }
  .hero-bg{
    position:absolute;inset:0;z-index:0;
    width:100%;height:100%;object-fit:cover;object-position:center 30%;
    animation:bloomPop 2s cubic-bezier(.16,.84,.44,1) both;
    will-change:transform,opacity,filter;
  }
  .hero::before{
    content:'';position:absolute;inset:0;
    background:
      radial-gradient(ellipse 80% 70% at 50% 42%, rgba(28,10,5,0.30), transparent 72%),
      linear-gradient(180deg,
        rgba(28,10,5,0.50) 0%,
        rgba(28,10,5,0.30) 32%,
        rgba(28,10,5,0.34) 60%,
        rgba(38,14,9,0.50) 82%,
        rgba(46,17,11,0.62) 93%,
        var(--bg) 100%);
    z-index:1;
  }
  .hero-inner{position:relative;z-index:2;max-width:1360px;margin:0 auto;width:100%;text-align:center;display:flex;flex-direction:column;align-items:center;}
  .hero-inner::before{
    content:'';position:absolute;
    top:-60px;left:50%;transform:translateX(-50%);
    width:min(1500px,160%);height:calc(100% + 120px);
    background:radial-gradient(ellipse 60% 65% at 50% 42%, rgba(28,10,5,0.34), rgba(28,10,5,0.18) 55%, transparent 78%);
    z-index:-1;
    pointer-events:none;
  }
  .hero-inner > *{opacity:0;animation:fadeUp .8s cubic-bezier(.16,.84,.44,1) forwards;}
  .hero .eyebrow{margin-bottom:26px;animation-delay:.05s;justify-content:center;}
  .hero h1{animation-delay:.16s;}
  .hero p.lede{animation-delay:.32s;}
  .hero-actions{animation-delay:.46s;}
  .hero-stats{animation-delay:.6s;}
  .hero h1{
    font-family:var(--font-display);
    font-weight:800;
    font-size:clamp(40px,7vw,84px);
    line-height:1.1;
    letter-spacing:-0.01em;
    max-width:1300px;
    text-shadow:0 4px 30px rgba(0,0,0,0.55), 0 1px 0 rgba(0,0,0,0.3);
  }
  .hero h1 .grad{
    background:linear-gradient(100deg,var(--cyan),var(--azure) 55%,var(--violet));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }
  .hero h1 .subline{
    display:block;
    font-size:0.32em;
    font-weight:600;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--text-mid);
    margin-top:14px;
  }
  .word-rotator{
    display:inline-block;
    transition:opacity .35s ease, transform .35s ease, filter .35s ease;
    will-change:opacity, transform;
  }
  .word-rotator.swap{opacity:0;transform:translateY(10px);filter:blur(6px);}
  .hero p.lede{
    margin-top:26px;
    font-size:17px;line-height:1.7;
    color:var(--text-mid);
    max-width:560px;
    margin-left:auto;margin-right:auto;
    text-shadow:0 2px 16px rgba(0,0,0,0.6);
  }
  .hero-actions{display:flex;gap:16px;margin-top:40px;flex-wrap:wrap;justify-content:center;}
  .hero-stats{
    margin-top:72px;margin-left:auto;margin-right:auto;
    display:flex;justify-content:center;flex-wrap:wrap;
    border-top:1px solid var(--line);
    padding-top:28px;
    max-width:820px;
    text-align:center;
  }
  .hero-stats div{padding:0 32px;}
  .hero-stats .num{font-family:var(--font-display);font-weight:700;font-size:26px;color:var(--text-hi);}
  .hero-stats .lbl{font-size:12px;color:var(--text-dim);margin-top:4px;letter-spacing:.02em;}

  /* white text over the bloom wallpaper (image hero on a light site) */
  .hero{color:#fff;}
  .hero .eyebrow{color:#ffd9a8;}
  .hero .eyebrow::before{background:#ffd9a8;}
  .hero h1{color:#fff;}
  .hero h1 .grad{background:linear-gradient(100deg,#ffe9a8,#ffb45e 55%,#ff7a3c);-webkit-background-clip:text;background-clip:text;color:transparent;}
  .hero h1 .subline{color:rgba(255,255,255,0.88);}
  .hero p.lede{color:rgba(255,255,255,0.9);}
  .hero-stats{border-top-color:rgba(255,255,255,0.30);}
  .hero-stats .num{color:#ffcf8a;text-shadow:0 2px 14px rgba(0,0,0,0.45);}
  .hero-stats .lbl{color:rgba(255,255,255,0.82);text-shadow:0 1px 8px rgba(0,0,0,0.4);}
  .hero .btn-ghost{border-color:rgba(255,255,255,0.5);color:#fff;}
  .hero .btn-ghost:hover{border-color:#fff;background:rgba(255,255,255,0.14);}

  /* ---------- about ---------- */
  #about{
    position:relative;
    overflow:hidden;
    isolation:isolate;
  }
  #about::before{
    content:'';
    position:absolute;inset:0;z-index:0;
    background:
      radial-gradient(ellipse 55% 60% at 12% 0%, rgba(216,59,1,0.06), transparent 60%),
      radial-gradient(ellipse 50% 55% at 90% 100%, rgba(110,20,35,0.05), transparent 60%);
  }
  #about .wrap, #about .about-rail{position:relative;z-index:2;}

  /* ---------- about (timeline rail) ---------- */
  .about-rail{
    display:grid;grid-template-columns:24px 1fr;gap:0 40px;
  }
  .rail-line{position:relative;}
  .rail-line::before{
    content:'';position:absolute;top:8px;bottom:8px;left:11px;width:1px;
    background:linear-gradient(180deg,var(--cyan),transparent);
  }
  .rail-dot{
    width:23px;height:23px;border-radius:50%;
    background:radial-gradient(circle,var(--cyan),rgba(217,72,27,0.15));
    animation:pulseRing 2.4s ease-out infinite;
  }
  .about-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}

  /* ---------- domains ---------- */
  .domains-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden;}
  .domain-cell{
    background:var(--bg-panel);
    padding:38px 32px;
    transition:background .3s ease;
    position:relative;
  }
  .domain-cell::before{
    content:'';position:absolute;left:0;top:0;bottom:0;width:2px;
    background:linear-gradient(180deg,var(--cyan),var(--violet));
    transform:scaleY(0);transform-origin:top;
    transition:transform .35s cubic-bezier(.16,.84,.44,1);
  }
  .domain-cell:hover::before{transform:scaleY(1);}
  .domain-cell:hover{background:var(--bg-panel-2);}
  .domain-index{
    font-family:var(--font-mono);font-size:12px;color:var(--text-dim);
    margin-bottom:22px;display:block;
    transition:color .3s ease;
  }
  .domain-cell:hover .domain-index{color:var(--cyan);}
  .domain-cell h3{
    font-family:var(--font-display);font-weight:700;font-size:20px;margin-bottom:12px;
    display:flex;align-items:center;gap:10px;
  }
  .domain-cell h3 .dot{width:8px;height:8px;border-radius:2px;background:var(--cyan);transition:transform .3s ease, box-shadow .3s ease;}
  .domain-cell:hover h3 .dot{transform:scale(1.5) rotate(45deg);}
  /* Microsoft logo colors across the six domains */
  .domain-cell:nth-child(1) .dot{background:#f25022;}
  .domain-cell:nth-child(2) .dot{background:#7fba00;}
  .domain-cell:nth-child(3) .dot{background:#00a4ef;}
  .domain-cell:nth-child(4) .dot{background:#ffb900;}
  .domain-cell:nth-child(5) .dot{background:#d83b01;}
  .domain-cell:nth-child(6) .dot{background:#6e1423;}
  .domain-cell p{color:var(--text-mid);font-size:14px;line-height:1.7;}

  /* ---------- Microsoft Technologies for Students ---------- */
  #ms-tech{background:linear-gradient(180deg, transparent, rgba(255,252,250,0.5) 20%, rgba(255,252,250,0.5) 80%, transparent);}
  .ms-group{margin-bottom:44px;}
  .ms-group:last-child{margin-bottom:0;}
  .ms-group-head{display:flex;align-items:baseline;gap:16px;margin-bottom:18px;flex-wrap:wrap;}
  .ms-group-head h3{font-family:var(--font-display);font-weight:700;font-size:19px;color:var(--text-hi);display:flex;align-items:center;gap:10px;}
  .ms-group-head h3::before{content:'';width:11px;height:11px;border-radius:2px;flex-shrink:0;}
  /* one Microsoft logo color per resource group */
  .ms-g0 .ms-group-head h3::before{background:#f25022;}
  .ms-g1 .ms-group-head h3::before{background:#7fba00;}
  .ms-g2 .ms-group-head h3::before{background:#00a4ef;}
  .ms-g3 .ms-group-head h3::before{background:#ffb900;}
  .ms-group-head p{color:var(--text-dim);font-size:13px;}
  .ms-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px;}
  .ms-link{
    display:flex;flex-direction:column;gap:8px;min-width:0;
    background:linear-gradient(180deg,var(--bg-panel),var(--bg-panel-2));
    border:1px solid var(--line);
    border-radius:12px;
    padding:20px 20px 18px;
    position:relative;
    transition:border-color .3s ease, transform .3s cubic-bezier(.16,.84,.44,1), box-shadow .3s ease;
  }
  .ms-link:hover{transform:translateY(-4px);border-color:rgba(217,72,27,0.4);box-shadow:0 16px 32px -20px rgba(216,59,1,0.55);}
  .ms-link .ms-label{
    font-family:var(--font-display);font-weight:600;font-size:14.5px;color:var(--text-hi);
    display:flex;align-items:center;justify-content:space-between;gap:8px;
  }
  .ms-link .ms-label svg{width:13px;height:13px;stroke:var(--cyan);fill:none;flex-shrink:0;transition:transform .25s ease;}
  .ms-link:hover .ms-label svg{transform:translate(3px,-3px);}
  .ms-link .ms-desc{font-size:12.5px;line-height:1.55;color:var(--text-mid);}

  /* ---------- collaboration ---------- */
  .collab-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-bottom:28px;}
  .collab-feature{
    display:flex;justify-content:space-between;align-items:center;gap:28px;flex-wrap:wrap;
    background:linear-gradient(120deg, rgba(216,59,1,0.12), rgba(110,20,35,0.12));
    border:1px solid var(--line);border-radius:16px;
    padding:34px 36px;margin-bottom:28px;
    transition:border-color .3s ease, transform .3s ease;
  }
  .collab-feature:hover{border-color:rgba(217,72,27,0.4);transform:translateY(-3px);}
  .collab-feature .cf-eyebrow{
    font-family:var(--font-mono);font-size:14px;letter-spacing:.14em;text-transform:uppercase;
    color:var(--amber);margin-bottom:10px;
  }
  .collab-feature h3{font-family:var(--font-display);font-weight:700;font-size:22px;color:var(--text-hi);}
  .collab-feature p{color:var(--text-mid);font-size:14px;line-height:1.7;margin-top:8px;max-width:560px;}
  .collab-feature .cf-link{
    display:inline-flex;align-items:center;gap:8px;white-space:nowrap;
    font-family:var(--font-mono);font-size:12.5px;color:var(--cyan);
    border:1px solid rgba(217,72,27,0.3);border-radius:999px;padding:10px 18px;
    transition:background .25s ease, border-color .25s ease, transform .25s ease;
  }
  .collab-feature .cf-link:hover{background:rgba(217,72,27,0.08);border-color:rgba(217,72,27,0.55);transform:translateY(-2px);}
  .collab-feature .cf-link svg{width:13px;height:13px;fill:currentColor;flex-shrink:0;}
  .collab-actions{
    display:flex;gap:16px;flex-wrap:wrap;align-items:center;justify-content:center;
    border:1px dashed rgba(216,59,1,0.3);
    border-radius:16px;padding:34px 32px;
    background:rgba(255,252,250,0.4);
  }
  .collab-actions p{color:var(--text-mid);font-size:14.5px;max-width:420px;line-height:1.7;}

  /* ---------- responsive (home only) ---------- */
  @media (max-width:960px){
    .about-cards{grid-template-columns:1fr;}
    .domains-grid{grid-template-columns:1fr;}
    .ms-grid{grid-template-columns:repeat(2,1fr);}
    .collab-grid{grid-template-columns:1fr;}
  }
  @media (max-width:560px){
    .ms-grid{grid-template-columns:1fr;}
  }
  @media (prefers-reduced-motion: reduce){
    .hero-inner > *{opacity:1 !important;transform:none !important;}
    .rail-dot{box-shadow:0 0 20px rgba(217,72,27,0.6);}
  }
</style>
</head>
<body>

<%- include("partials/nav") %>

<section class="hero" id="top">
  <img class="hero-bg" src="/hero-bloom.jpg" alt="" aria-hidden="true" onerror="this.remove()">
  <div class="hero-inner">
    <div class="eyebrow"><span class="ms-squares" aria-hidden="true"><i></i><i></i><i></i><i></i></span>Local student chapter · MSA-GNIT Kolkata</div>
    <h1>Microsoft Student <br><span class="grad word-rotator" id="heroWord">Ambassadors</span><span class="subline">GNIT Chapter</span></h1>
    <p class="lede">A student-run Microsoft Student Ambassadors Chapter at Guru Nanak Institute of Technology - is focused on building real projects and learning Microsoft technologies together.</p>
    <div class="hero-actions">
      <a href="https://mvp.microsoft.com/studentambassadors/?wt.mc_id=studentamb_474813" class="btn btn-primary">Become an Ambassador <span class="arrow">↗</span></a>
      <a href="#domains" class="btn btn-ghost">Explore our domains</a>
    </div>
    <div class="hero-stats">
      <div><div class="num" data-count="800" data-suffix="+">0</div><div class="lbl">Active members</div></div>
      <div><div class="num" data-count="6" data-suffix="">0</div><div class="lbl">Core domains</div></div>
      <div><div class="num" data-count="18" data-suffix="">0</div><div class="lbl">Microsoft resources</div></div>
    </div>
  </div>
</section>

<section id="about">
  <div class="wrap">
    <div class="about-rail">
      <div class="rail-line"><div class="rail-dot"></div></div>
      <div>
        <div class="eyebrow reveal">Who we are</div>
        <div class="section-head reveal" style="margin-top:16px;">
          <h2>About <span>Us</span></h2>
          <p>A chapter of learners at GNIT turning curiosity about Microsoft's tools and platforms into hands-on projects, workshops, and community.</p>
        </div>
        <div class="about-cards">
          <div class="card reveal">
            <div class="card-icon"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
            <h3>Vision</h3>
            <p>A campus where every student has hands-on access to Microsoft technologies, and sees software as a tool they can shape, not just consume.</p>
          </div>
          <div class="card reveal">
            <div class="card-icon"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75h.008v.008H12V6.75z"/></svg></div>
            <h3>Goal</h3>
            <p>Give GNIT students a direct path from first line of code to production-grade project, through events, mentorship, and a community that builds in public.</p>
          </div>
          <div class="card reveal">
            <div class="card-icon"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg></div>
            <h3>Mission</h3>
            <p>"Tech for GNIT." We run workshops, hackathons, and open build sessions that turn theory from the classroom into skills students actually use.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="domains">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">How the chapter runs</div>
        <h2>Our <span>Domains</span></h2>
      </div>
      <p>Six teams, one chapter. Every event and project passes through this pipeline, from first idea to final showcase.</p>
    </div>
    <div class="domains-grid">
      <div class="domain-cell reveal">
        <span class="domain-index">01</span>
        <h3><span class="dot"></span>Web Development</h3>
        <p>Builders of the chapter's sites and web tools — working with modern frameworks and Azure to ship interfaces people actually use.</p>
      </div>
      <div class="domain-cell reveal">
        <span class="domain-index">02</span>
        <h3><span class="dot"></span>App Development</h3>
        <p>Mobile and cross-platform engineers turning ideas into apps, from first prototype to something students can install and use daily.</p>
      </div>
      <div class="domain-cell reveal">
        <span class="domain-index">03</span>
        <h3><span class="dot"></span>Cloud Computing</h3>
        <p>The team behind our Azure workshops and infrastructure — deploying, scaling, and demystifying the cloud for every domain in the chapter.</p>
      </div>
      <div class="domain-cell reveal">
        <span class="domain-index">04</span>
        <h3><span class="dot"></span>AI-ML</h3>
        <p>Exploring machine learning and applied AI through hands-on builds, model experiments, and sessions on the tools shaping the field.</p>
      </div>
      <div class="domain-cell reveal">
        <span class="domain-index">05</span>
        <h3><span class="dot"></span>Data Science</h3>
        <p>Turning raw data into insight — analytics, visualization, and statistics workshops that make numbers make sense.</p>
      </div>
      <div class="domain-cell reveal">
        <span class="domain-index">06</span>
        <h3><span class="dot"></span>Cybersecurity</h3>
        <p>Drives the chapter's security awareness efforts and promotes best practices for protecting digital assets.</p>
      </div>
    </div>
  </div>
</section>

<!-- ---------- Microsoft Technologies for Students ---------- -->
<section id="ms-tech">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Official Microsoft destinations</div>
        <h2>Microsoft Technologies <span>for Students</span></h2>
      </div>
      <p>Everything a GNIT student needs to learn, build, and connect on the Microsoft ecosystem — straight from the Student Ambassadors handbook.</p>
    </div>
    <% msTech.forEach((group, gi) => { %>
      <div class="ms-group ms-g<%= gi % 4 %> reveal">
        <div class="ms-group-head">
          <h3><%= group.group %></h3>
          <p><%= group.desc %></p>
        </div>
        <div class="ms-grid">
          <% group.items.forEach(item => { %>
            <a class="ms-link" href="<%= item.url %>" target="_blank" rel="noopener">
              <span class="ms-label"><%= item.label %><svg viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10"/></svg></span>
              <span class="ms-desc"><%= item.desc %></span>
            </a>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<!-- ---------- collaboration ---------- -->
<section id="collaborate">
  <div class="wrap">
    <div class="section-head reveal">
      <div>
        <div class="eyebrow">Partner with us</div>
        <h2><span>Collaborations</span></h2>
      </div>
      <p>We team up with communities, speakers, and organizations that want to grow tech on campus. Here's how you can work with MSA-GNIT Chapter.</p>
    </div>
    <div class="collab-grid">
      <div class="card reveal">
        <div class="card-icon"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m5-2.13a4 4 0 100-8 4 4 0 000 8zm8 4a4 4 0 00-3-3.87M5 8.13A4 4 0 108 4a4 4 0 00-3 4.13z"/></svg></div>
        <h3>Communities &amp; Clubs</h3>
        <p>Student chapters, campus clubs, and tech communities — co-host workshops, hackathons, and cross-campus events with us.</p>
      </div>
      <div class="card reveal">
        <div class="card-icon"><svg fill="none" viewBox="0 0 24 24" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.97-4.03 9-9 9-1.5 0-2.9-.36-4.14-1L3 21l1.06-3.68A8.96 8.96 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z"/></svg></div>
        <h3>Speakers &amp; Mentors</h3>
        <p>Industry engineers, MVPs, and Gold Ambassadors — take a session, judge a hackathon, or mentor a student project team.</p>
